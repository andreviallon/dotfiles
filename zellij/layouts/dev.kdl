layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="file:/Users/andreviallon/.config/zellij/plugins/zjstatus.wasm" {
                format_left   "{mode}#[bg=#1E1E2F] {tabs}"
                format_center ""
                format_right  "{swap_layout}#[bg=#1E1E2F,fg=#494d64] #[bg=#3E1E2F,fg=#B0E7A8]î‚¶#[bg=#B0E7A8,fg=#000000]îž• #[bg=#363a4f,fg=#CBD6F7] {session}#[bg=#1E1E2F,fg=#363a4f]î‚´"
                format_space  "#[bg=#1E1E2F]"
                format_hide_on_overlength "true"
                format_precedence "crl"

                mode_normal        "#[bg=#1E1E2F,fg=#a6da95]î‚¶#[bg=#a6da95,fg=#1E1E2F,bold]NORNAL#[bg=#1E1E2F,fg=#a6da95]î‚´"
                mode_locked        "#[bg=#1E1E2F,fg=#363a4f]î‚¶#[bg=#363a4f,fg=#C8D6FA,bold]LOCKED#[bg=#1E1E2F,fg=#363a4f]î‚´"
                mode_resize        "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]RESIZE#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_pane          "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]PANE#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_tab           "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]TAB#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_scroll        "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]SCROLL#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_enter_search  "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]ENT SEARCH#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_search        "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]SEARCH#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_rename_tab    "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]RENAME TAB#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_rename_pane   "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]RENAME PANE#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_session       "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]SESSION#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_move          "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]MOVE#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_prompt        "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]PROMT#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_tmux          "#[bg=#1E1E2F,fg=#f5a97f]î‚¶#[bg=#f5a97f,fg=#1E1E2F,bold]TMUX#[bg=#1E1E2F,fg=#f5a97f]î‚´"

                // formatting for inactive tabs
                tab_normal              "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#313245,bold]{index} #[bg=#363a4f,fg=#8aadf4,bold] {name}{floating_indicator}#[bg=#1E1E2F,fg=#363a4f]î‚´"
                tab_normal_fullscreen   "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#313245,bold]{index} #[bg=#363a4f,fg=#8aadf4,bold] {name}{fullscreen_indicator}#[bg=#1E1E2F,fg=#363a4f]î‚´"
                tab_normal_sync         "#[bg=#1E1E2F,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#313245,bold]{index} #[bg=#363a4f,fg=#8aadf4,bold] {name}{sync_indicator}#[bg=#1E1E2F,fg=#363a4f]î‚´"

                // formatting for the current active tab
                tab_active              "#[bg=#1E1E2F,fg=#eed49f]î‚¶#[bg=#eed49f,fg=#1E1E2F,bold]{index} #[bg=#363a4f,fg=#eed49f,bold] {name}{floating_indicator}#[bg=#1E1E2F,fg=#363a4f]î‚´"
                tab_active_fullscreen   "#[bg=#1E1E2F,fg=#eed49f]î‚¶#[bg=#eed49f,fg=#1E1E2F,bold]{index} #[bg=#363a4f,fg=#eed49f,bold] {name}{fullscreen_indicator}#[bg=#1E1E2F,fg=#363a4f]î‚´"
                tab_active_sync         "#[bg=#1E1E2F,fg=#eed49f]î‚¶#[bg=#eed49f,fg=#1E1E2F,bold]{index} #[bg=#363a4f,fg=#eed49f,bold] {name}{sync_indicator}#[bg=#1E1E2F,fg=#363a4f]î‚´"

                // separator between the tabs
                tab_separator           "#[bg=#1E1E2F] "

                // indicators
                tab_sync_indicator       " ï‘ƒ"
                tab_fullscreen_indicator " ó°Š“"
                tab_floating_indicator   " ó°¹™"
            }
        }
        children
    }
    tab name="nvim" {
        pane command="nvim"
    }
    tab name="server" split_direction="vertical" {
        pane
        pane
        pane
    }
}
