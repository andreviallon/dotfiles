                mode_tab           "#[bg=#1E1E2F,fg=#8aadf4,bold]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]Tab#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_scroll        "#[bg=#1E1E2F,fg=#8aadf4,bold]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]Scroll#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_enter_search  "#[bg=#1E1E2F,fg=#8aadf4,bold]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]Ent Search#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_search        "#[bg=#1E1E2F,fg=#8aadf4,bold]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]Search Arch#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_rename_tab    "#[bg=#1E1E2F,fg=#8aadf4,bold]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]Rename Tab#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_rename_pane   "#[bg=#1E1E2F,fg=#8aadf4,bold]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]Rename Pane#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_session       "#[bg=#1E1E2F,fg=#8aadf4,bold]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]Session#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_move          "#[bg=#1E1E2F,fg=#8aadf4,bold]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]Move#[bg=#1E1E2F,fg=#8aadf4]î‚´"
                mode_prompt        "#[bg=#1E1E2F,fg=#8aadf4,bold]î‚¶#[bg=#8aadf4,fg=#1E1E2F,bold]Promt#[bg=#1E1E2F,fg=#8aadf4]î‚´"
