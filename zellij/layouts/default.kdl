layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="file:/Users/andreviallon/.config/zellij/plugins/zjstatus.wasm" {
                format_left   "{mode}#[bg=#1E1E2F] {tabs}"
                format_center ""
                format_right  "{swap_layout}#[bg=#1E1E2F,fg=#494d64] #[bg=#1E1E2F,fg=#CBD6F7]î‚¶î¯ˆ {session}î‚´"
                format_space  "#[bg=#1E1E2F]"
                format_hide_on_overlength "true"
                format_precedence "crl"

                border_enabled  "false"
                border_char     "â”€"
                border_format   "#[fg=#6C7086]{char}"
                border_position "top"

                hide_frame_for_single_pane "true"

                mode_normal        "#[bg=#1E1E2F,fg=#a6da95,bold]î‚¶#[bg=#a6da95,fg=#1E1E2F,bold]Normal#[bg=#1E1E2F,fg=#a6da95]î‚´"
