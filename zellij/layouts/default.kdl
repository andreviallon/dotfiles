                // formatting for inactive tabs
                tab_normal              "#[bg=#1E1E2F,fg=#8bd5ca]î‚¶#[bg=#8bd5ca,fg=#313245,bold]{index} #[bg=#363a4f,fg=#8bd5ca,bold] {name}{floating_indicator}#[bg=#1E1E2F,fg=#363a4f,bold]î‚´"
                tab_normal_fullscreen   "#[bg=#1E1E2F,fg=#8bd5ca]î‚¶#[bg=#8bd5ca,fg=#313245,bold]{index} #[bg=#363a4f,fg=#8bd5ca,bold] {name}{fullscreen_indicator}#[bg=#1E1E2F,fg=#363a4f,bold]î‚´"
