                // formatting for the current active tab
                tab_active              "#[bg=#1E1E2F,fg=#eed49f]î‚¶#[bg=#eed49f,fg=#313245,bold]{index} #[bg=#363a4f,fg=#eed49f,bold] {name}{floating_indicator}#[bg=#1E1E2F,fg=#363a4f,bold]î‚´"
